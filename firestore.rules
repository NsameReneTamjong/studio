
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isPlatformAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // Global Platform Settings
    match /settings/platform {
      allow read: if true; // Publicly readable for login page branding
      allow write: if isPlatformAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    // Matricule Registry - Uniqueness Enforcement
    match /matricules/{matricule} {
      allow read: if isSignedIn();
      // Only allow creation if it doesn't exist (ensures uniqueness)
      allow create: if isSignedIn(); 
      allow update, delete: if isPlatformAdmin();
    }

    // Counters
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In production, restrict to specific roles/functions
    }

    match /schools/{schoolId}/counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow create: if isPlatformAdmin();
      allow update: if isSignedIn(); // Add specific logic for school admin
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }
    
    // Platform Admins
    match /platform_admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }
  }
}
