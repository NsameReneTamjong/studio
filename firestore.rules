
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPlatformAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && 
        getUserData().role == 'SCHOOL_ADMIN' &&
        getUserData().schoolId == schoolId;
    }

    function isBursar(schoolId) {
      return isSignedIn() && 
        getUserData().role == 'BURSAR' &&
        getUserData().schoolId == schoolId;
    }

    function isTeacher(schoolId) {
      return isSignedIn() && 
        getUserData().role == 'TEACHER' &&
        getUserData().schoolId == schoolId;
    }

    // --- COLLECTION RULES ---

    // Global Platform Settings (Public Read for Branding)
    match /settings/platform {
      allow read: if true; 
      allow write: if isPlatformAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /featured_videos/{videoId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if true; 
      allow update: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == uid) || isSchoolAdmin(resource.data.schoolId);
    }
    
    // Schools
    match /schools/{docId} {
      allow read: if isSignedIn();
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin();
      allow delete: if isPlatformAdmin();
      
      // Sub-collections inside schools
      match /courses/{courseId} {
        allow read: if isSignedIn() && getUserData().schoolId == docId;
        allow write: if isSchoolAdmin(docId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if isSignedIn() && getUserData().schoolId == docId;
        allow write: if isTeacher(docId) || isSchoolAdmin(docId);
      }

      match /grades/{gradeId} {
        allow read: if isSignedIn() && (getUserData().schoolId == docId && (getUserData().role != 'STUDENT' || getUserData().uid == resource.data.studentUid));
        allow write: if isTeacher(docId) || isSchoolAdmin(docId);
      }

      match /payments/{paymentId} {
        allow read: if isSignedIn() && (getUserData().schoolId == docId && (getUserData().role != 'STUDENT' || getUserData().uid == resource.data.studentUid));
        allow write: if isBursar(docId) || isSchoolAdmin(docId);
      }

      match /announcements/{annId} {
        allow read: if isSignedIn() && getUserData().schoolId == docId;
        allow write: if isTeacher(docId) || isSchoolAdmin(docId) || isBursar(docId);
      }

      match /counters/{counterId} {
        allow read, write: if isSignedIn() && getUserData().schoolId == docId;
      }
    }

    match /matricules/{matricule} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if isPlatformAdmin();
    }

    match /counters/{counterId} {
      allow read, write: if isPlatformAdmin();
    }
    
    match /platform_admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
  }
}
