
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isPlatformAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SCHOOL_ADMIN' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    // --- COLLECTION RULES ---

    // Global Platform Settings
    match /settings/platform {
      allow read: if true; 
      allow write: if isPlatformAdmin();
    }

    // Public Marketing Assets
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /featured_videos/{videoId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }
    
    // Schools
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || isSchoolAdmin(schoolId);
    }

    // Announcements
    match /schools/{schoolId}/announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSchoolAdmin(schoolId) || isPlatformAdmin();
    }

    // Matricule Registry
    match /matricules/{matricule} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isPlatformAdmin();
    }

    // Counters
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /schools/{schoolId}/counters/{counterId} {
      allow read, write: if isSignedIn();
    }
    
    match /platform_admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
  }
}
