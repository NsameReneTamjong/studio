
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function isPlatformAdmin() {
      if (!isSignedIn()) return false;
      
      // 1. Check platform_admins collection (managed by framework/admin)
      if (exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid))) return true;
      
      // 2. Check user document role synced from app logic
      let userData = getUserData();
      return userData != null && 
             userData.role in ['SUPER_ADMIN', 'CEO', 'CTO', 'COO', 'INV', 'Investor'];
    }

    function isSchoolAdmin(schoolId) {
      if (!isSignedIn()) return false;
      if (isPlatformAdmin()) return true;
      
      let userData = getUserData();
      return userData != null && 
             (userData.role == 'SCHOOL_ADMIN') &&
             (userData.schoolId == schoolId);
    }

    // --- COLLECTION RULES ---

    match /settings/platform {
      allow read: if true; 
      allow write: if isPlatformAdmin();
    }

    match /testimonials/{testimonialId} {
      // 1. Authenticated users (not platform admins) can create new testimonials
      allow create: if isSignedIn() && !isPlatformAdmin();
      
      // 2. Platform Admins (CEO, CTO, INV, etc.) can read (list/get), update, and delete
      allow read, update, delete: if isPlatformAdmin();
    }

    match /featured_videos/{videoId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /feedback/{fbId} {
      allow read: if isPlatformAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isPlatformAdmin();
    }

    match /support/{supId} {
      allow read: if isPlatformAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isPlatformAdmin();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if true; 
      allow update: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == uid);
    }
    
    match /schools/{docId} {
      allow read: if isSignedIn();
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || isSchoolAdmin(docId);
      
      match /courses/{courseId} {
        allow read: if isSignedIn();
        allow write: if isSchoolAdmin(docId);
      }
      
      match /assignments/{assignmentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();

        match /submissions/{studentUid} {
          allow read, write: if isSignedIn();
        }
      }

      match /grades/{gradeId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /announcements/{annId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /counters/{counterId} {
        allow read, write: if isSignedIn();
      }
    }

    match /platform_admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /matricules/{matricule} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isPlatformAdmin();
    }

    match /counters/{counterId} {
      allow read, write: if isPlatformAdmin();
    }
  }
}
