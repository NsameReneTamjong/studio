
{
  "entities": {
    "School": {
      "title": "School",
      "description": "An educational institution in the SaaS platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "User",
      "description": "A user profile within a specific school or a platform-wide super admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string", "description": "The ID of the school this user belongs to. Null for super admins." },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "SCHOOL_ADMIN", "TEACHER", "STUDENT", "PARENT"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" }
      },
      "required": ["id", "role", "name", "email"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An online MCQ exam created by a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "schoolId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "passingScore": { "type": "number" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionText": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctOptionIndex": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "teacherId", "title", "subject", "questions"]
    },
    "ExamSubmission": {
      "title": "ExamSubmission",
      "description": "A student's attempt at an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "studentId": { "type": "string" },
        "answers": { "type": "array", "items": { "type": "number" } },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "passed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "examId", "studentId", "score"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between two or more participants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string", "format": "date-time" },
        "schoolId": { "type": "string" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "conversationId", "senderId", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": { "$ref": "#/entities/School" },
      "description": "School details."
    },
    "/exams/{examId}": {
      "schema": { "$ref": "#/entities/Exam" },
      "description": "Exam definitions."
    },
    "/exams/{examId}/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/ExamSubmission" },
      "description": "Student exam submissions."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Chat conversations."
    }
  }
}
