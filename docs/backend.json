
{
  "entities": {
    "School": {
      "title": "School",
      "description": "An educational institution in the SaaS platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "User",
      "description": "A user profile within a specific school or a platform-wide super admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string", "description": "The ID of the school this user belongs to. Null for super admins." },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "SCHOOL_ADMIN", "TEACHER", "STUDENT", "PARENT"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" }
      },
      "required": ["id", "role", "name", "email"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between two or more participants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string", "format": "date-time" },
        "schoolId": { "type": "string" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "conversationId", "senderId", "text", "timestamp"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Feedback sent from a school to the SaaS Super Admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "senderId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "senderId", "message"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Announcements sent by Super Admin to schools.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "targetSchoolId": { "type": "string", "description": "Specific school ID or 'all'." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "targetSchoolId"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": { "$ref": "#/entities/School" },
      "description": "School details and configuration."
    },
    "/schools/{schoolId}/feedbacks/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Feedbacks from schools to Super Admin."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Global or targeted announcements."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Chat conversations."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Individual chat messages."
    }
  }
}
