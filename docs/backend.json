
{
  "entities": {
    "Counter": {
      "title": "Counter",
      "description": "An atomic sequential counter used for matricule generation.",
      "type": "object",
      "properties": {
        "count": {
          "type": "number",
          "description": "The current highest sequence number used for a specific role/year/school combination."
        }
      },
      "required": ["count"]
    },
    "School": {
      "title": "School",
      "type": "object",
      "description": "Represents an educational institution.",
      "properties": {
        "id": { "type": "string", "description": "The unique School Base (e.g., GBHS1)." },
        "code": { "type": "string", "description": "e.g., GBHS" },
        "name": { "type": "string" },
        "principal": { "type": "string" },
        "domain": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "principal", "createdAt"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Platform user identified by their unique matricule.",
      "properties": {
        "id": { "type": "string", "description": "The generated Matricule." },
        "uid": { "type": "string", "firebase": "auth.uid" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["CEO", "CTO", "COO", "INV", "SCHOOL_ADMIN", "BURSAR", "LIBRARIAN", "TEACHER", "STUDENT", "PARENT"] },
        "schoolId": { "type": "string", "description": "Reference to School.id." },
        "email": { "type": "string", "format": "email" },
        "isLicensePaid": { "type": "boolean" },
        "aiRequestCount": { "type": "number" },
        "class": { "type": "string" },
        "section": { "type": "string" }
      },
      "required": ["id", "uid", "role", "email"]
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teacherUid": { "type": "string" },
        "teacherName": { "type": "string" },
        "targetClass": { "type": "string" },
        "type": { "type": "string", "enum": ["compulsory", "optional"] },
        "color": { "type": "string" }
      }
    },
    "Assignment": {
      "title": "Assignment",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "courseId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "maxMarks": { "type": "number" },
        "instructions": { "type": "string" }
      }
    },
    "Grade": {
      "title": "Grade",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string" },
        "studentName": { "type": "string" },
        "courseId": { "type": "string" },
        "seq1": { "type": "number" },
        "seq2": { "type": "number" },
        "term": { "type": "number" },
        "year": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["tuition", "uniform", "exams", "license"] },
        "method": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/settings/platform": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "logo": { "type": "string" }
        }
      },
      "description": "Global platform branding settings."
    },
    "/users/{uid}": {
      "schema": "#/entities/User",
      "description": "User records indexed by Auth UID."
    },
    "/schools/{docId}": {
      "schema": "#/entities/School",
      "description": "Registry of school nodes."
    },
    "/schools/{schoolId}/courses/{courseId}": {
      "schema": "#/entities/Course",
      "description": "Subjects offered by a school."
    },
    "/schools/{schoolId}/assignments/{assignmentId}": {
      "schema": "#/entities/Assignment",
      "description": "Tasks created by teachers."
    },
    "/schools/{schoolId}/grades/{gradeId}": {
      "schema": "#/entities/Grade",
      "description": "Academic performance records."
    },
    "/schools/{schoolId}/payments/{paymentId}": {
      "schema": "#/entities/Payment",
      "description": "Financial transaction ledger."
    },
    "/schools/{schoolId}/announcements/{annId}": {
      "schema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string" },
          "target": { "type": "string" }
        }
      },
      "description": "Institutional broadcast messages."
    }
  }
}
