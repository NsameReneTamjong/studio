
{
  "entities": {
    "Counter": {
      "title": "Counter",
      "description": "An atomic sequential counter used for matricule generation.",
      "type": "object",
      "properties": {
        "count": {
          "type": "number",
          "description": "The current highest sequence number used for a specific role/year/school combination."
        }
      },
      "required": ["count"]
    },
    "School": {
      "title": "School",
      "type": "object",
      "description": "Represents an educational institution.",
      "properties": {
        "id": { "type": "string", "description": "The unique School Base (e.g., GBHS1)." },
        "code": { "type": "string", "description": "e.g., GBHS" },
        "objectId": { "type": "number", "description": "Sequential school number." },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "objectId", "name", "createdAt"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Platform user identified by their unique matricule.",
      "properties": {
        "id": { "type": "string", "description": "The generated Matricule." },
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "role": { "type": "string", "enum": ["CEO", "CTO", "COO", "INV", "SCHOOL_ADMIN", "SUB_ADMIN", "BURSAR", "LIBRARIAN", "TEACHER", "STUDENT", "PARENT"] },
        "schoolId": { "type": "string", "description": "Reference to School.id." },
        "year": { "type": "string", "description": "YY format." },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" }
      },
      "required": ["id", "uid", "role", "year", "email"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/counters/platform_{year}_{roleCode}",
        "definition": {
          "entityName": "Counter",
          "description": "Global counters for platform-level roles (CEO, CTO, etc.)."
        }
      },
      {
        "path": "/schools/{schoolId}/counters/{year}_{roleCode}",
        "definition": {
          "entityName": "Counter",
          "description": "School-specific counters for roles (Teacher, Student, etc.)."
        }
      },
      {
        "path": "/users/{uid}",
        "definition": {
          "entityName": "User",
          "description": "User records indexed by Auth UID."
        }
      },
      {
        "path": "/matricules/{matricule}",
        "definition": {
          "entityName": "MatriculeRegistry",
          "description": "A registry to ensure global uniqueness of matricules. Maps Matricule -> UID.",
          "schema": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" }
            }
          }
        }
      }
    ]
  }
}
