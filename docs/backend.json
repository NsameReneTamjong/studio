
{
  "entities": {
    "School": {
      "title": "School",
      "description": "An educational institution in the SaaS platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "User",
      "description": "A user profile within a specific school or a platform-wide super admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string", "description": "The ID of the school this user belongs to. Null for super admins." },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "SCHOOL_ADMIN", "TEACHER", "STUDENT", "PARENT"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" }
      },
      "required": ["id", "role", "name", "email"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An online MCQ exam created by a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "schoolId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "passingScore": { "type": "number" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionText": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctOptionIndex": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "teacherId", "title", "subject", "questions"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A homework or project task assigned to students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "maxMarks": { "type": "number" }
      },
      "required": ["id", "title", "subject", "dueDate"]
    },
    "AssignmentSubmission": {
      "title": "AssignmentSubmission",
      "description": "A student's submission for a non-MCQ assignment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "content": { "type": "string" },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["submitted", "graded"] },
        "grade": { "type": "number" },
        "feedback": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "assignmentId", "studentId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": { "$ref": "#/entities/School" },
      "description": "School details."
    },
    "/exams/{examId}": {
      "schema": { "$ref": "#/entities/Exam" },
      "description": "Exam definitions."
    },
    "/assignments/{assignmentId}": {
      "schema": { "$ref": "#/entities/Assignment" },
      "description": "Assignment definitions."
    },
    "/assignments/{assignmentId}/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/AssignmentSubmission" },
      "description": "Student assignment submissions."
    }
  }
}
