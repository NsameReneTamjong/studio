
{
  "entities": {
    "Counter": {
      "title": "Counter",
      "description": "An atomic sequential counter used for matricule generation.",
      "type": "object",
      "properties": {
        "count": {
          "type": "number",
          "description": "The current highest sequence number used for a specific role/year/school combination."
        }
      },
      "required": ["count"]
    },
    "School": {
      "title": "School",
      "type": "object",
      "description": "Represents an educational institution.",
      "properties": {
        "id": { "type": "string", "description": "The unique School Base (e.g., GBHS1)." },
        "code": { "type": "string", "description": "e.g., GBHS" },
        "objectId": { "type": "number", "description": "Sequential school number." },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "objectId", "name", "createdAt"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Platform user identified by their unique matricule.",
      "properties": {
        "id": { "type": "string", "description": "The generated Matricule." },
        "uid": { "type": "string", "firebase": "auth.uid" },
        "role": { "type": "string", "enum": ["CEO", "CTO", "COO", "INV", "SCHOOL_ADMIN", "SUB_ADMIN", "BURSAR", "LIBRARIAN", "TEACHER", "STUDENT", "PARENT"] },
        "schoolId": { "type": "string", "description": "Reference to School.id." },
        "year": { "type": "string", "description": "YY format." },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "isLicensePaid": { "type": "boolean" }
      },
      "required": ["id", "uid", "role", "year", "email"]
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "target": { "type": "string" },
        "schoolId": { "type": "string" },
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "content": { "type": "string" },
        "schoolName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "FeaturedVideo": {
      "title": "FeaturedVideo",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "youtubeId": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/counters/platform_{year}_{roleCode}": {
      "schema": "#/entities/Counter",
      "description": "Global counters for platform-level roles."
    },
    "/schools/{schoolId}/counters/{year}_{roleCode}": {
      "schema": "#/entities/Counter",
      "description": "School-specific counters for roles."
    },
    "/users/{uid}": {
      "schema": "#/entities/User",
      "description": "User records indexed by Auth UID."
    },
    "/matricules/{matricule}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" }
        }
      },
      "description": "Registry to ensure global uniqueness of matricules."
    },
    "/testimonials/{testimonialId}": {
      "schema": "#/entities/Testimonial",
      "description": "Publicly visible testimonials published by Super Admin."
    },
    "/featured_videos/{videoId}": {
      "schema": "#/entities/FeaturedVideo",
      "description": "Publicly visible YouTube videos managed by CEO."
    },
    "/schools/{schoolId}/announcements/{announcementId}": {
      "schema": "#/entities/Announcement",
      "description": "School-specific broadcasts."
    }
  }
}
